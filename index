<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Marketing Agency</title>

<style>
/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

/* BODY */
body {
    background: linear-gradient(135deg, #050510, #0a0f2c);
    color: #fff;
    overflow-x: hidden;
}

/* HEADER */
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 50px;
}

/* LOGO */
.logo {
    font-size: 28px;
    font-weight: bold;
    letter-spacing: 2px;
    position: relative;
    color: #00eaff;
}

.logo::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 2px;
    background: #00eaff;
    bottom: -5px;
    left: 0;
    animation: glowLine 2s infinite alternate;
}

@keyframes glowLine {
    from {opacity: 0.3;}
    to {opacity: 1;}
}

/* HERO */
.hero {
    text-align: center;
    padding: 80px 20px;
}

.hero h1 {
    font-size: 50px;
    background: linear-gradient(90deg, #00eaff, #0077ff);
    -webkit-background-clip: text;
    color: transparent;
}

.hero p {
    margin-top: 20px;
    max-width: 700px;
    margin-inline: auto;
    opacity: 0.8;
}

/* BUTTON */
.btn {
    margin-top: 30px;
    padding: 15px 30px;
    border: none;
    background: linear-gradient(90deg, #00eaff, #0077ff);
    color: #000;
    font-weight: bold;
    cursor: pointer;
    border-radius: 30px;
    transition: 0.3s;
}

.btn:hover {
    transform: scale(1.1);
}

/* SECTION */
.section {
    padding: 60px 40px;
    max-width: 1100px;
    margin: auto;
}

/* CARD */
.card {
    background: rgba(255,255,255,0.05);
    padding: 30px;
    border-radius: 15px;
    margin-top: 20px;
    backdrop-filter: blur(10px);
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-10px);
}

/* GRID */
.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
    gap: 20px;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 30px;
    opacity: 0.6;
}

/* ANIMATION */
.fade {
    opacity: 0;
    transform: translateY(30px);
    transition: 1s;
}

.fade.show {
    opacity: 1;
    transform: translateY(0);
}
</style>

</head>
<body>

<header>
    <div class="logo">Marketing Agency</div>
</header>

<section class="hero fade">
    <h1>Future Marketing Engine</h1>
    <p>
        A complete digital framework designed to streamline campaigns, manage clients,
        and deliver performance insights in one unified system.
    </p>

    <button class="btn" onclick="contact()">Contact on WhatsApp</button>
</section>

<section class="section fade">
    <h2>About Repository</h2>
    <div class="card">
        <p>
        This repository represents a complete digital framework for a modern marketing agency,
        designed to streamline campaign creation, client management, and performance tracking.
        Built with scalability and adaptability in mind, it serves as a customizable foundation
        for agencies of all sizes.
        </p>
    </div>
</section>

<section class="section fade">
    <h2>Core Features</h2>
    <div class="grid">
        <div class="card">Campaign Planning & Automation</div>
        <div class="card">Audience Segmentation</div>
        <div class="card">Content Scheduling</div>
        <div class="card">Analytics Dashboard</div>
    </div>
</section>

<section class="section fade">
    <h2>System Power</h2>
    <div class="card">
        <p>
        Supports multi-channel marketing across social media, email, search engines,
        and web platforms. Automation reduces repetitive tasks while analytics provide
        actionable insights for optimized performance.
        </p>
    </div>
</section>

<section class="section fade">
    <h2>Collaboration & Flexibility</h2>
    <div class="card">
        <p>
        Includes role-based access, version control, and full customization options.
        Deploy locally or adapt to cloud environments with API integrations.
        </p>
    </div>
</section>

<footer>
    © 2026 Marketing Agency | Future Digital Systems
</footer>

<script>
/* SCROLL ANIMATION */
const elements = document.querySelectorAll('.fade');

window.addEventListener('scroll', () => {
    elements.forEach(el => {
        const position = el.getBoundingClientRect().top;
        const screenHeight = window.innerHeight;

        if(position < screenHeight - 100){
            el.classList.add('show');
        }
    });
});

/* WHATSAPP CONTACT */
function contact(){
    window.open("https://wa.me/923253059147", "_blank");
}

/* INITIAL LOAD */
window.onload = () => {
    elements.forEach(el => el.classList.add('show'));
};
</script>

</body>
</html>
